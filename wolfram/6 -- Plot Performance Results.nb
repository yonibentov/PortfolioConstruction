Cell[CellGroupData[{
Cell["Backtest on Simulated Data", "Title",
 CellChangeTimes->{{3.978737030072489*^9, 
  3.978737038189808*^9}},ExpressionUUID->"50974dd8-e901-4eb1-be11-\
c6e167927068"],

Cell["\<\
This is part 2 of 2 of the supplemental material for Sec. 11.\
\>", "Subtitle",
 CellChangeTimes->{{3.978735312750987*^9, 3.978735331759879*^9}, {
  3.978737049898831*^9, 
  3.978737049993002*^9}},ExpressionUUID->"6ff4a615-f06a-4fd5-b547-\
3c2620da256d"],

Cell[TextData[{
 "Instructions: Read performance data from storage ",
 StyleBox["after",
  FontSlant->"Italic"],
 " running the C program."
}], "Text",
 CellChangeTimes->{{3.97519642758206*^9, 3.975196468275426*^9}},
 Background->RGBColor[
  1, 0.85, 0.85],ExpressionUUID->"9c5a1982-7646-430a-97f8-e94795f87c44"],

Cell[TextData[{
 "Usage note: \n - The notebook that ",
 "generates historical prices simulates and writes all runs at once \
(sequentially but automatically). \n - The C program that determines the \
optimal policy for all states and stages, then imports the historical prices \
and executes the optimal policy on them, also processes all runs (again, \
sequentially but automatically). \n - In contrast, this notebook works ",
 StyleBox["per run",
  FontSlant->"Italic"],
 ". Choose which run to import here:"
}], "Text",
 CellChangeTimes->{{3.97873889939669*^9, 3.978739128930893*^9}},
 Background->RGBColor[
  1, 0.85, 0.85],ExpressionUUID->"4d0d6d22-96f8-4145-ae2c-f07b144cf38e"],

