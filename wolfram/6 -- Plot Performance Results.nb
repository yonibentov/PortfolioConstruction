  3.978737909509466*^9}, {3.978738034949562*^9, 3.978738036835197*^9}, {
  3.978738074781567*^9, 3.978738075535687*^9}, {3.978738390806262*^9, 
  3.9787384053598623`*^9}},ExpressionUUID->"d721078f-11bd-4574-965b-\
98b6860f0c74"],

Cell[TextData[{
 "\t",
 Cell[BoxData[{
  FormBox[
   RowBox[{"w", "=", 
    RowBox[{
     FractionBox[
      RowBox[{
       RowBox[{"a", "(", "S", ")"}], "-", "r"}], 
      SuperscriptBox["\[Sigma]", "2"]], "=", 
     RowBox[{
      FractionBox["1", 
       SuperscriptBox["\[Sigma]", "2"]], "[", 
      RowBox[{
       RowBox[{"\[Mu]", "(", "x", ")"}], "+", 
       FractionBox[
        SuperscriptBox["\[Sigma]", "2"], "2"], "-", "r"}], "]"}]}]}], 
   TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{"     ", 
    RowBox[{"=", 
     RowBox[{
      FractionBox["1", 
       SuperscriptBox["\[Sigma]", "2"]], "[", 
      RowBox[{
       RowBox[{"-", 
        RowBox[{"\[Theta]", "(", 
         RowBox[{"x", "-", "m"}], ")"}]}], "+", 
       FractionBox[
        SuperscriptBox["\[Sigma]", "2"], "2"], "-", "r"}], "]"}]}]}], 
   TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{"     ", 
    RowBox[{"=", 
     RowBox[{
      FractionBox["1", 
       SuperscriptBox["\[Sigma]", "2"]], 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"-", 
         RowBox[{"\[Theta]", " ", "[", 
          RowBox[{
           RowBox[{"ln", "(", 
            FractionBox["S", 
             SubscriptBox["S", "0"]], ")"}], "-", "m"}], "]"}]}], "+", 
        FractionBox[
         SuperscriptBox["\[Sigma]", "2"], "2"], "-", "r"}], "}"}]}]}]}], 
   TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{"     ", 
    RowBox[{"=", 
     RowBox[{
      FractionBox["1", 
       SuperscriptBox["\[Sigma]", "2"]], 
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{"-", "\[Theta]"}], " ", 
         RowBox[{"ln", "(", 
          FractionBox["S", 
           SubscriptBox["S", "0"]], ")"}]}], "+", 
        RowBox[{"\[Theta]", " ", "m"}], " ", "+", 
        FractionBox[
         SuperscriptBox["\[Sigma]", "2"], "2"], "-", "r"}], "}"}]}]}]}], 
   TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{"     ", 
    RowBox[{"=", 
     RowBox[{
      FractionBox["1", 
       SuperscriptBox["\[Sigma]", "2"]], 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"\[Theta]", " ", "m"}], " ", "+", 
          FractionBox[
           SuperscriptBox["\[Sigma]", "2"], "2"], "-", "r"}], ")"}], "[", 
        RowBox[{"1", "-", 
         RowBox[{
          FractionBox["\[Theta]", 
           RowBox[{
            RowBox[{"\[Theta]", " ", "m"}], " ", "+", " ", 
            FractionBox[
             SuperscriptBox["\[Sigma]", "2"], "2"], " ", "-", " ", "r"}]], 
          RowBox[{"ln", "(", 
           FractionBox["S", 
            SubscriptBox["S", "0"]], ")"}]}]}], "]"}], " ", "."}]}]}]}], 
   TraditionalForm]}],ExpressionUUID->"efe717e5-8163-487b-a103-c185509f857a"]
}], "Text",
