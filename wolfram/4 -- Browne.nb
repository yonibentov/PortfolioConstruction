Cell[BoxData[
 RowBox[{"browneVelocityFunctionPlot", "=", 
  RowBox[{
   RowBox[{
    RowBox[{"Plot", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"r", " ", "W"}], "-", 
       RowBox[{
        FractionBox[
         RowBox[{
          RowBox[{"(", 
           RowBox[{"a", "-", "r"}], ")"}], "/", "2"}], 
         RowBox[{"Sqrt", "[", 
          RowBox[{"2", "\[Pi]", " ", 
           SuperscriptBox["\[Sigma]", "2"], 
           RowBox[{"(", 
            RowBox[{"T", "-", "#"}], ")"}]}], "]"}]], 
        RowBox[{"Exp", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"-", 
            FractionBox["1", "2"]}], 
           SuperscriptBox[
            RowBox[{"y", "[", 
             RowBox[{"W", ",", "#"}], "]"}], "2"]}], "-", 
          RowBox[{"r", 
           RowBox[{"(", 
            RowBox[{"T", "-", "#"}], ")"}]}]}], "]"}]}]}], ",", 
      RowBox[{"{", 
       RowBox[{"W", ",", "0", ",", "1"}], "}"}], ",", "\[IndentingNewLine]", 
