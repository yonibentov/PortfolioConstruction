Cell[BoxData[
 RowBox[{
  RowBox[{"y", "[", 
   RowBox[{"W_", ",", "t_"}], "]"}], ":=", 
  RowBox[{"InverseCDF", "[", 
   RowBox[{
    RowBox[{"NormalDistribution", "[", 
     RowBox[{"0", ",", "1"}], "]"}], ",", 
    RowBox[{
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{"r", 
       RowBox[{"(", 
        RowBox[{"T", "-", "t"}], ")"}]}]], "W"}]}], "]"}]}]], "Input",
