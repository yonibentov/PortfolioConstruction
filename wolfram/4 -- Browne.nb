Cell[BoxData[
 RowBox[{"browneOptimalPositionPlot", "=", 
  RowBox[{
   RowBox[{
    RowBox[{"Plot", "[", 
     RowBox[{
      RowBox[{
       FractionBox["1", 
        RowBox[{"Sqrt", "[", 
         RowBox[{"2", "\[Pi]", " ", 
          SuperscriptBox["\[Sigma]", "2"], 
          RowBox[{"(", 
           RowBox[{"T", "-", "#"}], ")"}]}], "]"}]], 
       RowBox[{"Exp", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"-", 
           FractionBox["1", "2"]}], 
          SuperscriptBox[
           RowBox[{"y", "[", 
            RowBox[{"W", ",", "#"}], "]"}], "2"]}], "-", 
         RowBox[{"r", 
