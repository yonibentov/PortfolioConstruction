Cell[CellGroupData[{

Cell["Simulate Price Histories", "Section",
 CellChangeTimes->{{3.9729675722092333`*^9, 3.972967575111217*^9}, {
  3.975196341939745*^9, 3.975196342606471*^9}, {3.978735341141852*^9, 
  3.97873535200219*^9}},ExpressionUUID->"d330b821-4c54-4b4c-9205-\
da16a3d62d59"],

Cell[CellGroupData[{

Cell["Simulate a geometric mean-reverting process", "Subsection",
 CellChangeTimes->{{3.973223488436449*^9, 
  3.973223499610268*^9}},ExpressionUUID->"62a323b5-ead8-44f7-a023-\
8464aa6ebd88"],

Cell["\<\
While Wolfram has a GeometricBrownianMotion[], it does not have a \
GeometricOrnsteinUhlenbeck[]. I will program my own using the more general \
ItoProcess[].\
\>", "Text",
 CellChangeTimes->{{3.973223508171447*^9, 3.9732235924718437`*^9}, {
  3.9787354394297857`*^9, 3.978735443197706*^9}, {3.9787356071032047`*^9, 
  3.9787356321751223`*^9}},ExpressionUUID->"295217c0-ecc7-471f-b206-\
a931cfbd739f"],

Cell[TextData[{
 "The Ornstein-Uhlenbeck model in log-price, ",
 Cell[BoxData[
  FormBox[
   RowBox[{"x", "\[Congruent]", 
    RowBox[{"ln", "(", 
     FractionBox["S", 
      SubscriptBox["S", "0"]], ")"}]}], TraditionalForm]],ExpressionUUID->
  "8853a419-80df-462a-aa0d-46b0f3beda52"],
 ", is (see Sec. 10.1 of the paper)\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"dx", "(", "t", ")"}], "=", " ", 
    RowBox[{
     RowBox[{"\[Sigma]", " ", 
      RowBox[{"Z", "(", "t", ")"}], " ", 
      RowBox[{"\[Sqrt]", "dt"}]}], "-", 
     RowBox[{"\[Theta]", " ", "\[Bullet]", " ", 
      RowBox[{"(", 
       RowBox[{"x", "-", "m"}], ")"}], "dt"}]}]}], TraditionalForm]],
  ExpressionUUID->"1c83aa18-ba18-45e4-bbcb-c208f82811c2"],
 " ,\nwhere ",
 Cell[BoxData[
  FormBox["\[Sigma]", TraditionalForm]],ExpressionUUID->
  "fea8aa8b-6f29-4d16-8705-5f04d28927ae"],
 " is the volatility, ",
 Cell[BoxData[
  FormBox["m", TraditionalForm]],ExpressionUUID->
  "f0f576b7-e834-4c36-9199-b5b7c6a3f71f"],
 " is the asymptotic mean, and ",
 Cell[BoxData[
  FormBox["\[Theta]", TraditionalForm]],ExpressionUUID->
  "0e38cd77-d58e-434b-b234-ca7bb5715b50"],
 " is the mean-reversion speed. \nThe relation between ",
 Cell[BoxData[
  FormBox[
   RowBox[{"dx", "(", "t", ")"}], TraditionalForm]],ExpressionUUID->
  "eab8dcbf-11ec-4320-8935-00f56778a07d"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"dS", "(", "t", ")"}], TraditionalForm]],ExpressionUUID->
  "0fb8fb00-a54e-4150-99ad-27f0818370b6"],
 " is\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    FractionBox[
     RowBox[{"dS", "(", "t", ")"}], 
     RowBox[{"S", "(", "t", ")"}]], "=", 
    RowBox[{
     RowBox[{"dx", "(", "t", ")"}], "+", 
     RowBox[{
      FractionBox[
       SuperscriptBox["\[Sigma]", "2"], "2"], "dt"}]}]}], TraditionalForm]],
  ExpressionUUID->"d0c47752-641e-4186-8e05-9db266059567"],
 " .\nTherefore, the geometric Ornstein-Uhlenbeck process is \n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"dS", "(", "t", ")"}], "=", " ", 
    RowBox[{
     RowBox[{
      RowBox[{"[", 
       RowBox[{
        RowBox[{
         RowBox[{"-", "\[Theta]"}], " ", "\[Bullet]", " ", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"ln", "(", 
            FractionBox["S", 
             SubscriptBox["S", "0"]], ")"}], "-", "m"}], ")"}]}], "+", 
        FractionBox[
         SuperscriptBox["\[Sigma]", "2"], "2"]}], "]"}], 
      RowBox[{"S", "(", "t", ")"}], "dt"}], "+", 
     RowBox[{"\[Sigma]", " ", 
      RowBox[{"S", "(", "t", ")"}], 
      RowBox[{"dB", "(", "t", ")"}]}]}]}], TraditionalForm]],ExpressionUUID->
  "08a4bbf3-5ea2-462f-9e63-8156521c9c90"],
 " . "
}], "Text",
 InitializationCell->True,
 CellChangeTimes->{{3.9732236410471373`*^9, 3.9732238667478743`*^9}, {
  3.9732239338598127`*^9, 3.973224017762618*^9}, {3.975164776928842*^9, 
