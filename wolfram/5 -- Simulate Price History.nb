Cell["\<\
I will define an interface in the style of OrnsteinUhlenbeckProcess[]:\
\>", "Text",
 CellChangeTimes->{{3.9732240985010033`*^9, 3.973224113931837*^9}, {
  3.978736160659863*^9, 
  3.978736179390141*^9}},ExpressionUUID->"e78c42d1-7b47-49f3-80c9-\
d671d37c0457"],

Cell[BoxData[
 RowBox[{
  RowBox[{"GeometricOrnsteinUhlenbeckProcess", "[", 
   RowBox[{"m_", ",", "\[Sigma]_", ",", "\[Theta]_", ",", "S0_"}], "]"}], ":=", 
  RowBox[{"ItoProcess", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{
          RowBox[{"-", "\[Theta]"}], 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"Log", "[", 
             FractionBox[
              RowBox[{"S", "[", "t", "]"}], "S0"], "]"}], "-", "m"}], ")"}]}],
          "+", 
         FractionBox[
          SuperscriptBox["\[Sigma]", "2"], "2"]}], ")"}], 
       RowBox[{"S", "[", "t", "]"}]}], ",", 
      RowBox[{"\[Sigma]", " ", 
       RowBox[{"S", "[", "t", "]"}]}]}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"S", ",", "S0"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"t", ",", "0"}], "}"}]}], "\[IndentingNewLine]", 
   "]"}]}]], "Input",
 CellChangeTimes->{{3.973224081915689*^9, 3.973224260941943*^9}, {
  3.973224313487834*^9, 3.9732243142131863`*^9}, {3.9732243562870827`*^9, 
  3.973224356999132*^9}, {3.975164829316876*^9, 3.975164833709238*^9}},
 CellLabel->"In[8]:=",ExpressionUUID->"a162c0c8-f961-4b21-b998-a47d4357279d"]
}, Open  ]],

