Notebook[{

Cell[CellGroupData[{
Cell["Optimal Policy for Power-Law Utility", "Title",
 CellChangeTimes->{{3.9780103620239677`*^9, 
  3.97801039125518*^9}},ExpressionUUID->"44964c94-9353-499a-96c0-\
257a2184cf1e"],

Cell["Supplemental material for Secs. 5.3 and 5.4.", "Subtitle",
 CellChangeTimes->{{3.978010400861279*^9, 3.9780104099025183`*^9}, 
   3.978012923655039*^9},ExpressionUUID->"9a6c59ed-d9ef-4e7f-a41a-\
b22ea7453059"],

Cell[CellGroupData[{

Cell["Ratio of Policies", "Section",
 CellChangeTimes->{{3.978010419385194*^9, 
  3.978010420947613*^9}},ExpressionUUID->"2c13823a-b40f-4335-b722-\
74517991fcaf"],

Cell["\<\
The ratio of the optimal policy for power-law utility [Eq. (5.17)] and \
log-utility [Eq. (5.11)] is\
\>", "Text",
 CellChangeTimes->{{3.978010427131503*^9, 
  3.978010468353527*^9}},ExpressionUUID->"98c8e6f2-6cf0-47dc-883e-\
bbe65653b59e"],

Cell[BoxData[
 RowBox[{
  RowBox[{"ratio", "[", 
   RowBox[{"p_", ",", "\[Alpha]_"}], "]"}], ":=", 
  RowBox[{
   FractionBox[
    RowBox[{
     SuperscriptBox["p", 
      FractionBox["1", 
       RowBox[{"1", "-", "\[Alpha]"}]]], "-", 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{"1", "-", "p"}], ")"}], 
      FractionBox["1", 
       RowBox[{"1", "-", "\[Alpha]"}]]]}], 
    RowBox[{
     SuperscriptBox["p", 
      FractionBox["1", 
       RowBox[{"1", "-", "\[Alpha]"}]]], "+", 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{"1", "-", "p"}], ")"}], 
      FractionBox["1", 
       RowBox[{"1", "-", "\[Alpha]"}]]]}]], "/", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{"2", "p"}], "-", "1"}], ")"}]}]}]], "Input",
 CellChangeTimes->{{3.973774177764761*^9, 3.973774187189837*^9}},
 CellLabel->"In[1]:=",ExpressionUUID->"2c9e96f3-f514-48b0-a96d-b89d9780f9a4"]
}, Open  ]],

