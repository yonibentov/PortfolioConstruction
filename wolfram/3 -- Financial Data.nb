Cell[BoxData[
 FractionBox[
  SuperscriptBox["\[ExponentialE]", 
   RowBox[{"-", 
    FractionBox[
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{"x", "-", 
        RowBox[{"t", " ", "\[Mu]"}]}], ")"}], "2"], 
     RowBox[{"2", " ", "t", " ", 
      SuperscriptBox["\[Sigma]", "2"]}]]}]], 
  SuperscriptBox["\[Sigma]", "2"]]], "Output",
 CellChangeTimes->{{3.974403432702217*^9, 3.9744034813074627`*^9}, 
   3.974433871017223*^9, 3.9744361336723547`*^9, 3.974457643386632*^9, 
