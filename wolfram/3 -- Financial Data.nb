       "\"\< \[PlusMinus] \>\"", ",", 
       RowBox[{"SetPrecision", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{"uncertaintyInDriftYear", "[", 
            RowBox[{"[", "i", "]"}], "]"}], ")"}], 
