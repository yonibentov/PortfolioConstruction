Cell[CellGroupData[{

Cell["Brownian Motion in Log-Price", "Section",
 CellChangeTimes->{{3.974402922439775*^9, 
  3.9744029288220778`*^9}},ExpressionUUID->"193657a2-2c17-4050-8791-\
1cd2639cff48"],

Cell[BoxData[
 RowBox[{
  RowBox[{"posteriorAction", "[", 
   RowBox[{"x_", ",", "t_", ",", "\[Sigma]_", ",", "\[Mu]_"}], "]"}], ":=", 
  RowBox[{"Block", "[", 
   RowBox[{
    RowBox[{"{", "n", "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"n", "=", 
      RowBox[{"Length", "@", "x"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Length", "@", "t"}], "!=", "n"}], ",", 
       RowBox[{
       "Print", "[", "\"\<Error: x and t have different lengths\>\"", "]"}]}],
       "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"Sum", "[", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{
         FractionBox["1", 
          RowBox[{"2", 
           SuperscriptBox["\[Sigma]", "2"], 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"t", "[", 
              RowBox[{"[", 
               RowBox[{"i", "+", "1"}], "]"}], "]"}], "-", 
             RowBox[{"t", "[", 
              RowBox[{"[", "i", "]"}], "]"}]}], ")"}]}]], 
         SuperscriptBox[
          RowBox[{"(", 
           RowBox[{
            RowBox[{"x", "[", 
             RowBox[{"[", 
              RowBox[{"i", "+", "1"}], "]"}], "]"}], "-", 
            RowBox[{"x", "[", 
             RowBox[{"[", "i", "]"}], "]"}], "-", 
            RowBox[{"\[Mu]", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{"t", "[", 
                RowBox[{"[", 
                 RowBox[{"i", "+", "1"}], "]"}], "]"}], "-", 
               RowBox[{"t", "[", 
                RowBox[{"[", "i", "]"}], "]"}]}], ")"}]}]}], ")"}], "2"]}], 
        "\[IndentingNewLine]", ",", 
        RowBox[{"{", 
         RowBox[{"i", ",", "1", ",", 
          RowBox[{"n", "-", "1"}]}], "}"}]}], "]"}], "\[IndentingNewLine]", 
      "+", 
      RowBox[{"n", " ", 
       RowBox[{"Log", "[", "\[Sigma]", "]"}]}]}]}]}], " ", 
   RowBox[{"(*", " ", 
    RowBox[{"Normalization", " ", "plus", " ", "Jeffreys", " ", "prior"}], 
    " ", "*)"}], "\[IndentingNewLine]", "]"}]}]], "Input",
 CellChangeTimes->{{3.974402978325597*^9, 3.9744031691002274`*^9}, {
  3.974403232049795*^9, 3.974403282190937*^9}, {3.974403326980541*^9, 
  3.9744033392471857`*^9}, {3.974403383499462*^9, 3.9744033900828457`*^9}, {
  3.9746469535757008`*^9, 3.974646955520589*^9}},
 CellLabel->"In[9]:=",ExpressionUUID->"900723a2-e02f-4015-804b-bb42cec14be5"],

