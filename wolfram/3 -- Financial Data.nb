    RowBox[{
     RowBox[{"Print", "[", 
      RowBox[{
       RowBox[{"stocks", "[", 
        RowBox[{"[", "i", "]"}], "]"}], ",", "\"\<:\>\""}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<  \[Sigma] = \>\"", ",", 
       RowBox[{"SetPrecision", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{"\[Sigma]", "/.", 
            RowBox[{"estimatesMonth", "[", 
             RowBox[{"[", "i", "]"}], "]"}]}], ")"}], 
          RowBox[{"Sqrt", "[", "numberOfTradingDaysPerYear", "]"}], "*", 
          "100"}], ",", "2"}], "]"}], ",", "\"\< \[PlusMinus] \>\"", ",", 
       RowBox[{"SetPrecision", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{"uncertaintyInVolatilityMonth", "[", 
            RowBox[{"[", "i", "]"}], "]"}], ")"}], 
          RowBox[{"Sqrt", "[", "numberOfTradingDaysPerYear", "]"}], "*", 
          "100"}], ",", "2"}], "]"}], ",", 
       "\"\< %/\!\(\*SuperscriptBox[\(year\), \(1/2\)]\)\>\""}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<  \[Mu] = \>\"", ",", 
       RowBox[{"SetPrecision", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{"\[Mu]", "/.", 
            RowBox[{"estimatesMonth", "[", 
             RowBox[{"[", "i", "]"}], "]"}]}], ")"}], 
          "numberOfTradingDaysPerYear", "*", "100"}], ",", "2"}], "]"}], ",", 
       "\"\< \[PlusMinus] \>\"", ",", 
       RowBox[{"SetPrecision", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{"uncertaintyInDriftMonth", "[", 
            RowBox[{"[", "i", "]"}], "]"}], ")"}], 
          "numberOfTradingDaysPerYear", "*", "100"}], ",", "2"}], "]"}], ",", 
       "\"\< %/year\>\""}], "]"}]}], ",", "\[IndentingNewLine]", 
    RowBox[{"{", 
