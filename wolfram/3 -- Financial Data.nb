          RowBox[{"Sqrt", "[", "numberOfTradingDaysPerYear", "]"}], "*", 
          "100"}], ",", "2"}], "]"}], ",", "\"\< \[PlusMinus] \>\"", ",", 
       RowBox[{"SetPrecision", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{"uncertaintyInVolatilityYear", "[", 
            RowBox[{"[", "i", "]"}], "]"}], ")"}], 
          RowBox[{"Sqrt", "[", "numberOfTradingDaysPerYear", "]"}], "*", 
          "100"}], ",", "2"}], "]"}], ",", 
       "\"\< %/\!\(\*SuperscriptBox[\(year\), \(1/2\)]\)\>\""}], "]"}], ";", 
