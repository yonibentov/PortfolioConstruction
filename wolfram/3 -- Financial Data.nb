   3.97449028950031*^9, 3.974595053362563*^9, 3.9746394489490957`*^9, 
   3.97464696011862*^9, 3.974647275567053*^9, {3.974647315716751*^9, 
   3.974647340063815*^9}, 3.978014047458981*^9, 3.9788331754045963`*^9},
 CellLabel->"Out[11]=",ExpressionUUID->"4befb99d-2960-42b0-a594-6fa998ebc966"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Integrate", "[", 
  RowBox[{
   RowBox[{"Exp", "[", 
    RowBox[{"-", 
     RowBox[{"posteriorAction", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"0", ",", "x"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"0", ",", "t"}], "}"}], ",", "\[Sigma]", ",", "\[Mu]"}], 
      "]"}]}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", 
     RowBox[{"-", "\[Infinity]"}], ",", "\[Infinity]"}], "}"}], ",", 
   RowBox[{"Assumptions", "->", 
    RowBox[{
     RowBox[{"\[Sigma]", ">", "0"}], "&&", 
     RowBox[{"t", ">", "0"}]}]}]}], "]"}]], "Input",
 CellChangeTimes->{{3.978833184804138*^9, 3.978833222986588*^9}},
 CellLabel->"In[13]:=",ExpressionUUID->"636da25b-e6f6-404c-820f-0d4b9d93855b"],

Cell[BoxData[
 FractionBox[
  RowBox[{
   SqrtBox[
    RowBox[{"2", " ", "\[Pi]"}]], " ", 
   SqrtBox["t"]}], "\[Sigma]"]], "Output",
 CellChangeTimes->{{3.978833206853146*^9, 3.978833224603372*^9}},
 CellLabel->"Out[13]=",ExpressionUUID->"f6ccfb13-ff5c-43a2-81e2-d82f25cda38b"]
}, Open  ]],

Cell[TextData[{
 "The overall ",
 Cell[BoxData[
  FormBox[
   FractionBox["1", "\[Sigma]"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "0702f424-6e2b-44b5-8237-a64bf15f6621"],
 " is the Jeffreys prior. The overall ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    UnderoverscriptBox[
     RowBox[{"\[Product]", " "}], 
     RowBox[{"i", "=", "1"}], 
     RowBox[{"N", "-", "1"}]], 
    FractionBox["1", 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{"2", "\[Pi]", "  ", 
        SubscriptBox["\[CapitalDelta]t", "i"]}], ")"}], 
      RowBox[{"1", "/", "2"}]]]}], TraditionalForm]],ExpressionUUID->
  "9eeb67fa-e990-4d9e-ab3d-2f1c5e047492"],
 " is not relevant for determination of the maximum, so I dropped it."
}], "Text",
 CellChangeTimes->{{3.974403497850751*^9, 3.974403565163286*^9}, {
  3.974647429080258*^9, 3.974647429161683*^9}, {3.978833265556611*^9, 
  3.9788332806208057`*^9}},ExpressionUUID->"f6d7113f-8168-42bb-bb0c-\
4eebde9c05f0"]
}, Open  ]],

