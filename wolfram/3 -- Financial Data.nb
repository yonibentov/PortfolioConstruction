Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"posteriorActionYear", "[", 
    RowBox[{"\[Sigma]", ",", "\[Mu]"}], "]"}], "=", 
   RowBox[{"Table", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"posteriorAction", "[", 
      RowBox[{
       RowBox[{"logDailyClosingPricesYear", "[", 
