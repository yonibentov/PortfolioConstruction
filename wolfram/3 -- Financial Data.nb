     "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<  \[Sigma] = \>\"", ",", 
       RowBox[{"SetPrecision", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{"\[Sigma]", "/.", 
            RowBox[{"estimatesYear", "[", 
