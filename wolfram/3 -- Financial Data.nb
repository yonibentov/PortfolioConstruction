4b896344f95e"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"posteriorAction", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"x1", ",", "x2", ",", "x3"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"t1", ",", "t2", ",", "t3"}], "}"}], ",", "\[Sigma]", ",", 
   "\[Mu]"}], "]"}]], "Input",
 CellChangeTimes->{{3.9744032918410187`*^9, 3.974403302365068*^9}},
 CellLabel->"In[10]:=",ExpressionUUID->"7722e206-af37-4b27-a6fe-28214b5df096"],

Cell[BoxData[
 RowBox[{
  FractionBox[
   SuperscriptBox[
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "x1"}], "+", "x2", "-", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", "t1"}], "+", "t2"}], ")"}], " ", "\[Mu]"}]}], ")"}], 
    "2"], 
   RowBox[{"2", " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "t1"}], "+", "t2"}], ")"}], " ", 
    SuperscriptBox["\[Sigma]", "2"]}]], "+", 
  FractionBox[
   SuperscriptBox[
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "x2"}], "+", "x3", "-", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", "t2"}], "+", "t3"}], ")"}], " ", "\[Mu]"}]}], ")"}], 
    "2"], 
   RowBox[{"2", " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "t2"}], "+", "t3"}], ")"}], " ", 
    SuperscriptBox["\[Sigma]", "2"]}]], "+", 
  RowBox[{"3", " ", 
   RowBox[{"Log", "[", "\[Sigma]", "]"}]}]}]], "Output",
 CellChangeTimes->{3.974403302786426*^9, 3.974403343650704*^9, 
  3.9744338692593603`*^9, 3.974436132255352*^9, 3.974457641675632*^9, 
  3.974459161363964*^9, 3.97446774477044*^9, 3.974482230091199*^9, 
  3.97449028816535*^9, 3.9745950533592978`*^9, 3.9746394489459887`*^9, 
  3.974646960116454*^9, 3.9780140458825407`*^9, 3.9788331719824667`*^9},
 CellLabel->"Out[10]=",ExpressionUUID->"b70778dd-ad1d-4df2-a1e5-4400fcd3ad95"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Exp", "[", 
  RowBox[{"-", 
   RowBox[{"posteriorAction", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"0", ",", "x"}], "}"}], ",", 
